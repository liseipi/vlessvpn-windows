<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="VlessClient.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="VLESS Client"
    >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ title bar ═══════════════════════════════════════════════ -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="44"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" x:Name="TitleBarIcon"
                   Width="24" Height="24"
                   Margin="16,0,0,0" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="VLESS Client" Margin="8,0,0,0"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- ═══ content ══════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" Padding="20,8,20,16">
            <StackPanel Spacing="14">

                <!-- ── status card ─────────────────────────────────────── -->
                <Border CornerRadius="10" Padding="18"
                        Background="{StaticResource CardBackground}"
                        BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="连接状态" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       CharacterSpacing="1"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border x:Name="StatusDot" Width="8" Height="8" CornerRadius="4"
                                        Background="{StaticResource StatusStoppedBrush}"
                                        VerticalAlignment="Center"/>
                                <TextBlock x:Name="StatusText" Text="未连接"
                                           FontSize="16" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="ConnectionCountText"
                                       Text="活动连接: 0" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>

                        <Button x:Name="ToggleButton" Grid.Column="1"
                                Width="72" Height="72" CornerRadius="36"
                                Padding="0"
                                BorderThickness="0"
                                Click="ToggleButton_Click">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver"   Color="#22C55E"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#16A34A"/>
                                <SolidColorBrush x:Key="ButtonBackgroundDisabled"     Color="#9CA3AF"/>
                            </Button.Resources>
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#EF4444" Offset="0"/>
                                    <GradientStop Color="#F97316" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <FontIcon x:Name="ToggleIcon" Glyph="&#xE768;" FontSize="26"
                                      Foreground="White"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- ── server config card ───────────────────────────────── -->
                <Border CornerRadius="10" Padding="18"
                        Background="{StaticResource CardBackground}"
                        BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1">
                    <StackPanel Spacing="10">
                        <Grid>
                            <TextBlock Text="服务器配置" FontSize="14" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
                                <Button Content="导入" Click="ImportBtn_Click"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Height="30" FontSize="12"/>
                                <Button Content="导出" Click="ExportBtn_Click"
                                        Height="30" FontSize="12"/>
                                <Button Content="新建" Click="NewConfigBtn_Click"
                                        Height="30" FontSize="12"/>
                            </StackPanel>
                        </Grid>

                        <ComboBox x:Name="ConfigSelector" HorizontalAlignment="Stretch"
                                  PlaceholderText="选择一个服务器配置..."
                                  SelectionChanged="ConfigSelector_SelectionChanged"/>

                        <Border x:Name="ConfigDetail" Visibility="Collapsed"
                                CornerRadius="6" Padding="12"
                                Background="{ThemeResource LayerFillColorDefaultBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                                    <TextBlock Text="服务器" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock x:Name="DetailServer" TextTrimming="CharacterEllipsis"
                                               FontSize="13"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
                                    <TextBlock Text="端口" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock x:Name="DetailPort" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                                    <TextBlock Text="传输" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock x:Name="DetailNetwork" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,8">
                                    <TextBlock Text="安全" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock x:Name="DetailSecurity" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="监听端口" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock x:Name="DetailListenPort" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,0"
                                            Orientation="Horizontal" Spacing="6"
                                            VerticalAlignment="Bottom">
                                    <Button Content="编辑" Click="EditConfigBtn_Click"
                                            Height="28" FontSize="11"/>
                                    <Button Content="删除" Click="DeleteConfigBtn_Click"
                                            Height="28" FontSize="11"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ── proxy settings card ──────────────────────────────── -->
                <Border CornerRadius="10" Padding="18"
                        Background="{StaticResource CardBackground}"
                        BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="代理设置" FontSize="14" FontWeight="SemiBold"/>

                        <StackPanel Spacing="4">
                            <TextBlock Text="本地端口 (SOCKS5 / HTTP)" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <NumberBox x:Name="Socks5PortBox" Value="10808"
                                       Minimum="1" Maximum="65535"
                                       SpinButtonPlacementMode="Inline"/>
                        </StackPanel>

                        <!-- 系统代理 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="系统代理" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="设置 Windows 系统代理（浏览器等应用生效）" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="SystemProxyToggle" Grid.Column="1"
                                          OffContent="" OnContent=""
                                          Toggled="SystemProxyToggle_Toggled"/>
                        </Grid>

                        <!-- LAN 共享 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="局域网共享" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="允许局域网内其他设备使用此代理" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="ShareOverLanToggle" Grid.Column="1"
                                          OffContent="" OnContent=""
                                          Toggled="ShareOverLanToggle_Toggled"/>
                        </Grid>

                        <!-- TUN toggle -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="TUN 全局模式" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="接管所有流量（需管理员权限）" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="TunToggle" Grid.Column="1"
                                          OffContent="" OnContent=""
                                          Toggled="TunToggle_Toggled"/>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- ── system settings card ─────────────────────────────── -->
                <Border CornerRadius="10" Padding="18"
                        Background="{StaticResource CardBackground}"
                        BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1">
                    <StackPanel Spacing="10">
                        <TextBlock Text="系统设置" FontSize="14" FontWeight="SemiBold"/>

                        <Grid>
                            <StackPanel>
                                <TextBlock Text="开机自启" FontSize="13"/>
                                <TextBlock Text="Windows 启动时自动运行" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="AutoStartToggle" HorizontalAlignment="Right"
                                          OffContent="" OnContent=""
                                          Toggled="AutoStartToggle_Toggled"/>
                        </Grid>

                        <Grid>
                            <StackPanel>
                                <TextBlock Text="最小化到托盘" FontSize="13"/>
                                <TextBlock Text="关闭窗口时隐藏到系统托盘" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="MinimizeToTrayToggle" HorizontalAlignment="Right"
                                          OffContent="" OnContent=""
                                          Toggled="MinimizeToTrayToggle_Toggled"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ log panel ════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Height="150" CornerRadius="10"
                Margin="20,0,20,0"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{StaticResource CardBorder}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Padding="12,8"
                        Background="{ThemeResource LayerFillColorAltBrush}"
                        CornerRadius="10,10,0,0">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE8BF;" FontSize="11"
                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <TextBlock Text="运行日志" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Content="清空" HorizontalAlignment="Right"
                                FontSize="11" Height="24" Padding="10,0"
                                Click="ClearLogBtn_Click"/>
                    </Grid>
                </Border>

                <ScrollViewer x:Name="LogScroller" Grid.Row="1"
                              HorizontalScrollBarVisibility="Auto">
                    <TextBlock x:Name="LogText"
                               FontFamily="Consolas" FontSize="11"
                               Padding="12,6"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"
                               IsTextSelectionEnabled="True"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══ status bar ═══════════════════════════════════════════════ -->
        <Border Grid.Row="3" Height="32" Padding="16,0"
                Background="Transparent">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Border x:Name="FooterDot" Width="6" Height="6" CornerRadius="3"
                            Background="{StaticResource StatusStoppedBrush}"/>
                    <TextBlock x:Name="FooterText" Text="就绪" FontSize="11"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="VLESS over WebSocket"
                           HorizontalAlignment="Right" FontSize="11"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           VerticalAlignment="Center" Opacity="0.6"/>
            </Grid>
        </Border>
    </Grid>
</Window>
